#!/bin/bash
# Bootstrap + launcher for Feedscript.app
# Must live at <project>/Feedscript.app/Contents/MacOS/Feedscript

APP_BUNDLE="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_DIR="$(dirname "$APP_BUNDLE")"
cd "$PROJECT_DIR"

LOG="$PROJECT_DIR/.app_launch.log"
exec > "$LOG" 2>&1

if [[ -f /opt/homebrew/bin/brew ]]; then eval "$(/opt/homebrew/bin/brew shellenv)"; fi
if [[ -f /usr/local/bin/brew ]]; then eval "$(/usr/local/bin/brew shellenv)"; fi
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

die() {
    osascript -e "display dialog \"$1\" buttons {\"OK\"} default button 1 with title \"Feedscript\"" >/dev/null 2>&1
    exit 1
}

if ! command -v python3 >/dev/null 2>&1; then
    die "Python 3 is required. Install it from python.org or run: brew install python@3.11"
fi

if [ ! -x "$PROJECT_DIR/venv/bin/python3" ]; then
    python3 -m venv "$PROJECT_DIR/venv" || die "Could not set up the app environment in the project folder."
    "$PROJECT_DIR/venv/bin/pip" install --upgrade pip >/dev/null 2>&1
fi

if ! "$PROJECT_DIR/venv/bin/python3" -c "import webview" 2>/dev/null; then
    "$PROJECT_DIR/venv/bin/pip" install pywebview || die "Could not install the app window library. Check $LOG for details."
fi

exec "$PROJECT_DIR/venv/bin/python3" "$PROJECT_DIR/launcher.py"
